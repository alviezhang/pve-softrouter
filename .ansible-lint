# https://ansible.readthedocs.io/projects/lint/configuring/
profile: production

skip_list:
  - yaml[line-length]
  - yaml[truthy]
  - name[casing]
  - var-naming[no-role-prefix] # vm_*/apt_* names are shared with existing consumers
  - jinja[spacing]
  - meta-runtime[unsupported-version] # PVE 8 bookworm ships ansible-core 2.14; we intentionally support it

warn_list:
  - command-instead-of-shell
  - command-instead-of-module
  - risky-shell-pipe
  - risky-file-permissions
  - name[missing]

offline: false
